# Ambiente virtual
.venv/
venv/

# Cache Python
__pycache__/
*.py[cod]

# Variáveis de ambiente e segredos
.env
.env.*
!.env.example
.streamlit/secrets.toml

# Testes
.pytest_cache/
.coverage
htmlcov/

# Arquivos processados gerados localmente
data/processed/*.csv
!data/processed/.gitkeep

# Bancos locais gerados pelo ETL
database/*.db
database/*.sqlite
database/*.sqlite3
!database/.gitkeep

# Logs locais
logs/*.log
!logs/.gitkeep

# Lotes importados pela interface
data/raw/imported/*.csv
!data/raw/imported/.gitkeep


# Transações manuais do usuário
data/raw/transacoes_manuais.csv



